# Copy this file to .env.local and fill in the values.
# .env.local is gitignored; never commit real credentials.

# --- Supabase ---------------------------------------------------------------
# Found in: Supabase Dashboard -> Project Settings -> API
# The URL is safe to expose; the anon key is designed to be public (RLS enforces access).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Server-only key used by trusted backend code to bypass RLS (e.g. admin operations,
# seed scripts). NEVER expose this to the browser and NEVER prefix it with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# --- Site -------------------------------------------------------------------
# Used for OAuth redirect URLs and email verification links.
# Dev: http://localhost:3000
# Prod: https://your-domain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- TMDB -------------------------------------------------------------------
# v4 "API Read Access Token" from https://www.themoviedb.org/settings/api
# This is a JWT starting with "eyJhbGci...". Server-only — never prefix with NEXT_PUBLIC_.
TMDB_ACCESS_TOKEN=YOUR-TMDB-V4-READ-ACCESS-TOKEN
